# ========================================================
# PEDE RAG Environment Configuration
# ========================================================

# 1. PENGATURAN DATABASE LOKAL (DEFAULT)
# Jika Anda ingin menyimpan vektor langsung di folder komputer Anda.
QDRANT_PATH="./qdrant_db"

# 2. PENGATURAN QDRANT CLOUD (OPSIONAL)
# Jika Anda ingin menyimpan vektor di Server Cloud (misal: australia-southeast1).
# Cukup hilangkan tanda '#' di bawah ini dan masukkan URL serta API Key Anda.
# Jika URL dan API Key ini terisi, sistem akan OTOMATIS mengabaikan database lokal.

# QDRANT_URL="https://67983937-4c0e-403a-9f44-9934c86743e9.australia-southeast1-0.gcp.cloud.qdrant.io:6333"
# QDRANT_API_KEY="masukkan_api_key_anda_disini"
